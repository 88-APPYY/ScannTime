{
  "name": "electron-process-monitor",
  "version": "1.0.0",
  "description": "Windows 进程监控应用 - 暗色主题",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run react-start\" \"npm run electron-start\"",
    "react-start": "react-scripts start",
    "electron-start": "electron .",
    "build": "react-scripts build",
    "electron-build": "electron-builder",
    "package": "npm run build && npm run electron-build"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "electron": "^28.0.0",
    "sqlite3": "^5.1.6",
    "recharts": "^2.8.2",
    "date-fns": "^2.30.0",
    "node-windows": "^1.0.0-beta.8",
    "electron-store": "^8.1.0",
    "electron-log": "^5.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron-builder": "^24.6.4",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.2.2"
  },
  "build": {
    "appId": "com.electron.processmonitor",
    "productName": "进程监控器",
    "directories": {
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "main.js",
      "preload.js"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/favicon.ico"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}